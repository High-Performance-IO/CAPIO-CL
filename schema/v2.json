{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CAPIO-CL Configuration Schema v2.0",
  "type": "object",
  "definitions": {
    "output_target": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["file", "dir"],
          "description": "Type of output target."
        },
        "mode": {
          "type": "string",
          "enum": ["update", "no_update"],
          "description": "Update mode for the output target."
        },
        "commit": {
          "type": "string",
          "description": "Commit rule for the output target."
        },
        "storage": {
          "type": "string",
          "enum": ["mem", "fs"],
          "description": "Optional storage backend."
        },
        "permanent": {
          "type": "boolean",
          "description": "Whether the output target is permanent."
        }
      },
      "required": ["kind", "mode", "commit"],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": { "const": "file" }
            },
            "required": ["kind"]
          },
          "then": {
            "properties": {
              "commit": {
                "type": "string",
                "pattern": "^(on_close(:[0-9]+)?|on_termination)$"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": { "const": "dir" }
            },
            "required": ["kind"]
          },
          "then": {
            "properties": {
              "commit": {
                "type": "string",
                "pattern": "^(on_close(:[0-9]+)?|n_files:[0-9]+|on_termination)$"
              }
            }
          }
        }
      ]
    },
    "workflow_step": {
      "type": "object",
      "properties": {
        "input_stream": {
          "type": "array",
          "description": "Input aliases or literal paths.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "output_stream": {
          "type": "object",
          "description": "Maps an output alias or path to its definition.",
          "propertyNames": {
            "type": "string",
            "minLength": 1
          },
          "additionalProperties": {
            "$ref": "#/definitions/output_target"
          },
          "minProperties": 1
        }
      },
      "required": ["input_stream", "output_stream"],
      "additionalProperties": false
    }
  },
  "properties": {
    "version": {
      "type": "string",
      "const": "2.0",
      "description": "Version of the CAPIO-CL configuration file"
    },
    "configuration": {
      "type": "string",
      "description": "TOML configuration file for runtime CAPIO-CL parameters"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Identifies the application workflow."
    },
    "aliases": {
      "type": "object",
      "description": "Groups files or directories under a convenient alias name.",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "exclude": {
      "type": "array",
      "description": "Paths or patterns to exclude.",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "io_graph": {
      "type": "object",
      "description": "Workflow steps and their I/O definitions.",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "$ref": "#/definitions/workflow_step"
      },
      "minProperties": 1
    }
  },
  "required": ["version", "name", "io_graph"],
  "additionalProperties": false
}
